# Optional: Cursor CLI uses CURSOR_API_KEY from environment for auth
# CURSOR_API_KEY=your_api_key_here

# Server
HOST=127.0.0.1
PORT=8080

# Cursor agent executable (name in PATH or full path)
# CURSOR_AGENT_CMD=agent

# Working directory for agent (default: server cwd).
# If first response is slow (~30s), set to a minimal dir (e.g. $HOME) so agent skips project indexing.
# CURSOR_AGENT_CWD=

# Request timeout in seconds (empty = no timeout)
# REQUEST_TIMEOUT=

# Allow agent to modify files (--force)
# CURSOR_AGENT_FORCE=false
